{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "The CutList",
  "version": "0.1.5",
  "identifier": "com.willbridewell.cutlist",
  "build": {
    "beforeDevCommand": "npm run next:dev",
    "beforeBuildCommand": "npm run build:release-assets",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "The CutList",
        "width": 1280,
        "height": 880,
        "minWidth": 960,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri:; connect-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "category": "Music",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
