# The CutList environment example.
# Copy this file to .env.local for local development. Never commit .env.local.

# Server-only. Allowed values: ollama, openai, gemini, none.
LLM_PROVIDER=gemini

# Server-only. Used only when LLM_PROVIDER=ollama.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=granite4.1:8b
# Server-only. Used only for Ollama gpt-oss models. Allowed values: low, medium, high.
OLLAMA_GPT_OSS_THINK=medium

# Server-only. Used only when LLM_PROVIDER=openai.
# Use a real key only in your shell environment, .env.local, or deployment secrets, never in source control.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Server-only. Used only when LLM_PROVIDER=gemini.
# If GEMINI_API_KEY is exported in your shell, .env.local can omit this value.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Server-only. Optional request timeout for LLM calls.
LLM_TIMEOUT_MS=120000

# Deprecated fallback only. Use the in-app Curator persona control instead.
# Allowed legacy values: sharp, classic, critic.
LLM_CURATOR_VOICE=

# Server-only. Set to 1 only while debugging locally; raw model output can include user text.
LLM_DEBUG_RAW=0

# Local-only. Set to 1 to print Tauri/backend/provider/LLM timing logs to stderr.
CUTLIST_DEBUG_TIMING=0
